# Template de variáveis — copiar para .env.local e preencher.
# Nunca commitar .env.local no git.

# -------------------------------------------------------------------
# Dashboard (Next.js)
# -------------------------------------------------------------------
# Connection string direta do PostgreSQL — usada pelas API Routes via postgres.js.
# Exemplo Supabase pooler: postgresql://USER:PASS@HOST:6543/postgres?sslmode=require
# Role recomendada: "app" (apenas CRUD nas tabelas do MVP, sem DDL, sem UPDATE em acesso_ficha).
DATABASE_URL=

# URL pública do app — usada em canonical tags e chamadas internas (default: http://localhost:3000)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -------------------------------------------------------------------
# Script de importação (ops/importer/import_csv.py)
# -------------------------------------------------------------------
# Mesma connection string, mas com role de serviço (DDL não, DML sim em postos e import_log).
DATABASE_URL_IMPORTER=

# Caminho do CSV oficial (pode ser absoluto ou relativo à raiz do projeto)
IMPORTER_CSV_PATH=./data/Postos_PLU_FLU_PIEZO_CIAS_BAT_MUNIC_UGRHI_SUB_OTTO-18-03-26a-csv.csv

# -------------------------------------------------------------------
# Worker de indexação (ops/indexer/)
# -------------------------------------------------------------------
# Connection string com role restrita: leitura em postos, escrita em arquivos_indexados / arquivos_orfaos / indexacao_log.
DATABASE_URL_INDEXER=

# Caminho UNC ou local que o worker varre (exemplo: \\servidor\\postos\\)
INDEXER_ROOT_PATH=

# -------------------------------------------------------------------
# Supabase (somente se for usar o dashboard do Supabase para DBA;
# o app não precisa dessas variáveis em runtime)
# -------------------------------------------------------------------
# SUPABASE_PROJECT_REF=
# SUPABASE_ACCESS_TOKEN=
